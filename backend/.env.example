# ─── WhatsApp CRM Backend Configuration ───────────────────────────────────────
# Copy this file to .env and fill in the values.

# Supabase Service Role Key (REQUIRED for backend to auto-save incoming WA messages to Supabase)
# Get it from: Supabase Dashboard → Project Settings → API → service_role (secret) key
# WARNING: Keep this key secret. Never commit it to git.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: Override default port (default: 3001)
# PORT=3001
