# ─── WhatsApp CRM Backend Configuration ───────────────────────────────────────
# Copy this file to .env and fill in the values.
# On Railway, set these as Environment Variables in the Railway dashboard.

# Supabase Service Role Key (REQUIRED for backend to auto-save incoming WA messages)
# Get it from: Supabase Dashboard → Project Settings → API → service_role (secret) key
# WARNING: Keep this key secret. Never commit .env to git.
SUPABASE_SERVICE_ROLE_KEY=

# Frontend URL for CORS (set to your Vercel deployment URL)
# Example: https://whadesk.vercel.app
FRONTEND_URL=

# Port (Railway sets this automatically — do not change on Railway)
# PORT=3001

# Optional: path to system Chromium binary (Railway sets this via nixpacks)
# PUPPETEER_EXECUTABLE_PATH=/run/current-system/sw/bin/chromium

# Optional: custom path to store WhatsApp session data
# Tip: on Railway, mount a Volume at this path to persist your WA session across deploys
# WA_SESSION_PATH=/data/wwebjs_auth
